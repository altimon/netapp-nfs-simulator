# NetApp ONTAP Simulator — site configuration
# Copy to config.env and edit for your lab. config.env is gitignored.

# SSH listen port for the simulator (default 2223; change if port is taken)
NETAPP_PORT=2223

# Simulator SSH credentials
NETAPP_USER=admin
NETAPP_PASS=netapp123

# NFS server subnet — clients in this range can mount the export
# Set to the subnet shared by your NFS server and NFS client VMs
NFS_SUBNET=172.16.153.0/24

# IP address of the NFS server (this host) — shown in network interface show
# Leave blank to auto-detect from the primary interface at setup time
NFS_SERVER_IP=

# Simulated ONTAP LIF IPs (shown by "network interface show")
# These are the storage IPs that would appear in a real ONTAP cluster.
# For interview practice, set DATA_LIF_IP to the IP clients would mount from.
ADMIN_LIF_IP=192.168.52.31
DATA_LIF_IP=192.168.52.42

# NFS client VM — used for automated cleanup between scenarios
# The simulator SSHes into this host to unmount /mnt and clean up test files.
# Leave NFS_CLIENT_IP blank to skip client-side cleanup.
NFS_CLIENT_IP=
NFS_CLIENT_USER=altimon
NFS_CLIENT_PASS=
NFS_CLIENT_MOUNT=/mnt
